DATABASE_URL="postgresql://postgres:postgres@localhost:5432/feasibility_os?schema=public"
API_PUBLIC_URL="http://localhost:4000"
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"
# Optional hosted Redis alternative:
# REDIS_URL="redis://default:password@host:6379"
# REDIS_TLS="false"
PORT="4000"
# Optional:
# ENABLE_DEMO_FALLBACK="true"
# In local non-production dev this defaults to true when unset.
# In hosted production set it explicitly to true only for public demo/testing deployments.
# Optional local diagnostics flags:
# DISABLE_SWAGGER="true"
# DISABLE_BULL="true"
