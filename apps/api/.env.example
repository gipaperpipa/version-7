DATABASE_URL="postgresql://postgres:postgres@localhost:5432/feasibility_os?schema=public"
API_PUBLIC_URL="http://localhost:4000"
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"
# Optional hosted Redis alternative:
# REDIS_URL="redis://default:password@host:6379"
# REDIS_TLS="false"
PORT="4000"
# Optional source parcel provider configuration:
# SOURCE_PARCEL_PROVIDER_MODE="REAL_ONLY"
# Use REAL_WITH_DEMO_FALLBACK for local/dev/demo deployments that should fall back to the seeded catalog.
# SOURCE_PARCEL_NOMINATIM_BASE_URL="https://nominatim.openstreetmap.org"
# SOURCE_PARCEL_NOMINATIM_USER_AGENT="FeasibilityOS/1.0 (+http://localhost:4000)"
# SOURCE_PARCEL_NOMINATIM_EMAIL=""
# SOURCE_PARCEL_NOMINATIM_COUNTRY_CODES="de"
# SOURCE_PARCEL_NOMINATIM_ACCEPT_LANGUAGE="de,en"
# SOURCE_PARCEL_HESSEN_CADASTRE_BASE_URL="https://www.geoportal.hessen.de/spatial-objects/710"
# SOURCE_PARCEL_HESSEN_CADASTRE_COLLECTION="cp:CadastralParcel"
# SOURCE_PARCEL_HESSEN_CADASTRE_WFS_BASE_URL="https://inspire-hessen.de/ows/services/org.2.d66ec21e-39e7-45c4-bf68-438e8baea882_wfs"
# SOURCE_PARCEL_HESSEN_CADASTRE_WFS_TYPENAME="cp:CadastralParcel"
# SOURCE_PARCEL_HESSEN_CADASTRE_USER_AGENT="FeasibilityOS/1.0 (+http://localhost:4000)"
# SOURCE_PARCEL_HESSEN_CADASTRE_BBOX_RADIUS_METERS="80"
# SOURCE_PARCEL_HESSEN_CADASTRE_MAX_SEED_COUNT="4"
# SOURCE_PARCEL_HESSEN_CADASTRE_BBOX_WEST="7.772467"
# SOURCE_PARCEL_HESSEN_CADASTRE_BBOX_SOUTH="49.395272"
# SOURCE_PARCEL_HESSEN_CADASTRE_BBOX_EAST="10.236414"
# SOURCE_PARCEL_HESSEN_CADASTRE_BBOX_NORTH="51.657789"
# SOURCE_PARCEL_CACHE_TTL_MINUTES="1440"
# SOURCE_PARCEL_REQUEST_TIMEOUT_MS="8000"
# Optional:
# ENABLE_DEMO_FALLBACK="true"
# In local non-production dev this defaults to true when unset.
# In hosted production set it explicitly to true only for public demo/testing deployments.
# Optional local diagnostics flags:
# DISABLE_SWAGGER="true"
# DISABLE_BULL="true"
