{
  "name": "@repo/web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "wait-on ../../packages/contracts/dist/index.js && next dev -p 3001",
    "build": "pnpm --filter @repo/contracts build && next build",
    "start": "next start -p 3001",
    "typecheck": "pnpm --filter @repo/contracts build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@repo/contracts": "workspace:*",
    "next": "^15.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4"
  }
}
